# ─────────────────────────────────────────────────────────────
# DaveAI — Vercel Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local for local dev, then add these
# same variables in your Vercel project dashboard:
#   vercel.com → your project → Settings → Environment Variables
#
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Your site URL (used in OpenRouter Referer header) ────────
SITE_URL=https://your-project.vercel.app


# ── Groq API Keys (primary LLM provider, free tier available) ─
# Add up to 10. The server will automatically rotate through
# them and fall back when rate-limited.
# Get keys at: https://console.groq.com/keys
GROQ_KEY_1=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_KEY_3=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GROQ_KEY_4=
# GROQ_KEY_5=


# ── Google Gemini API Keys (secondary fallback) ───────────────
# Free tier at: https://aistudio.google.com/app/apikey
GEMINI_KEY_1=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GEMINI_KEY_2=
# GEMINI_KEY_3=


# ── OpenRouter API Keys (tertiary fallback) ───────────────────
# Free models available at: https://openrouter.ai/keys
OPENROUTER_KEY_1=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENROUTER_KEY_2=


# ── Supabase (data persistence — chats, memories, settings) ───
# Get these from: supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx
# Service key is only needed if you use /api/imagine image uploads
# to Supabase Storage. The anon key is enough for DB operations.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx


# ── Web Search Keys (all optional — DDG fallback always works) ─
# Tavily (best for AI agents): https://tavily.com
TAVILY_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Serper (Google results): https://serper.dev
SERPER_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Brave Search: https://brave.com/search/api/
BRAVE_KEY=BSAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Image: remove.bg (optional — for background removal) ──────
# Free tier: 50 calls/month at https://www.remove.bg/api
# If not set, DaveAI falls back to its canvas-based method.
# REMOVE_BG_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────
# LOCAL DEV ONLY — these are set automatically on Vercel
# ─────────────────────────────────────────────────────────────
# VERCEL_URL is injected automatically by Vercel at build time.
# For local dev you can set it to localhost:
# VERCEL_URL=localhost:3000
